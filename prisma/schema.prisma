generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  uidentyId     String?       @unique // Lien Uidenty
  balance       Float         @default(0.0) // Balance Ui Currency
  transactions  Transaction[]
  messages      Message[]
  authAccount   AuthAccount?
  fdxConsents   FdxConsentGrant[]
  createdAt     DateTime      @default(now())
}

model Transaction {
  id              String   @id @default(cuid())
  amount          Float
  currency        String   @default("Ui")
  status          String   // PENDING, SUCCESS, FAILED
  type            String   // STRIPE, MOMO, CONVERSION
  traceabilityId  String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model AuthAccount {
  id               String        @id @default(cuid())
  userId           String        @unique
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  email            String        @unique
  passwordHash     String
  twoFactorEnabled Boolean       @default(false)
  twoFactorSecret  String?
  sessions         AuthSession[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model AuthSession {
  id         String      @id @default(cuid())
  accountId  String
  account    AuthAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash  String      @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime    @default(now())

  @@index([accountId])
  @@index([expiresAt])
}

model FdxConsentGrant {
  id              String                 @id
  userId          String?
  user            User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  status          String
  createdTime     DateTime               @default(now())
  expirationTime  DateTime?
  updatedTime     DateTime               @updatedAt
  durationType    String
  durationPeriod  Int?
  lookbackPeriod  Int?
  parties         Json
  resources       Json
  revocations     FdxConsentRevocation[]

  @@index([userId])
  @@index([status])
}

model FdxConsentRevocation {
  id         String          @id @default(cuid())
  consentId  String
  consent    FdxConsentGrant @relation(fields: [consentId], references: [id], onDelete: Cascade)
  status     String          @default("REVOKED")
  reason     String
  initiator  String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([consentId])
}
